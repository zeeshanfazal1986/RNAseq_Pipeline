// ─────────────────────────────────────────────────────────────────
// Nextflow configuration – RNAseq Pipeline
// Replaces: cluster.yaml + rnaseq_pipeline.sh (Snakemake)
// ─────────────────────────────────────────────────────────────────

// Default parameters (can be overridden on command line)
params {
    data        = "/home/a-m/fazal2/RNAseq_workflow"
    type        = "PE"
    fasta       = "/home/a-m/fazal2/xenograft/data/genome/human_mouse.fna"
    gtf         = "/home/a-m/fazal2/xenograft/data/genome/human_mouse.gtf"
    junction    = 99
    strand      = 2
    trim_length = 30
    trim_window = "4:18"
    trim_lead   = 28
    trim_trail  = 28
    outdir      = "results"
}

// ─────────────────────────────────────────────────────────────────
// Process resource labels  (mirrors cluster.yaml)
// ─────────────────────────────────────────────────────────────────
process {
    // Default for all processes
    cpus   = 1
    memory = '8 GB'

    withLabel: 'trim' {
        cpus   = 2
        memory = '8 GB'
    }

    withLabel: 'star' {
        cpus   = 10
        memory = '65 GB'
    }

    withLabel: 'counts' {
        cpus   = 4
        memory = '16 GB'
    }
}

// ─────────────────────────────────────────────────────────────────
// Execution profiles
// ─────────────────────────────────────────────────────────────────
profiles {

    // Local execution (for testing)
    standard {
        process.executor = 'local'
    }

    // SLURM cluster – mirrors rnaseq_pipeline.sh + cluster.yaml
    slurm {
        process {
            executor     = 'slurm'
            queue        = 'normal'
            clusterOptions = '--nodes=1'

            withLabel: 'star' {
                cpus         = 10
                memory       = '65 GB'
                queue        = 'normal'
            }

            withLabel: 'trim' {
                cpus         = 2
                memory       = '8 GB'
                queue        = 'normal'
            }

            withLabel: 'counts' {
                cpus         = 4
                memory       = '16 GB'
                queue        = 'normal'
            }
        }

        // Load cluster modules inside each process
        process.beforeScript = '''
            module load STAR/2.7.3a-IGB-gcc-8.2.0
            module load Trimmomatic
            module load Subread
        '''

        executor {
            name      = 'slurm'
            queueSize = 6
        }
    }
}

// ─────────────────────────────────────────────────────────────────
// Tracing / reports
// ─────────────────────────────────────────────────────────────────
report {
    enabled = true
    file    = "${params.outdir}/pipeline_report.html"
}

timeline {
    enabled = true
    file    = "${params.outdir}/timeline.html"
}

trace {
    enabled = true
    file    = "${params.outdir}/trace.txt"
}
